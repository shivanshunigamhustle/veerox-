# URL of the FastAPI backend. No trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Admin token — NOT a Next.js env var (never sent to the client via process.env).
# The user pastes this token into the /login page and it is stored in
# localStorage under the key "veerox_admin_token". The value must match
# ADMIN_TOKEN set in the backend's .env file.
# ADMIN_TOKEN=<paste-from-backend-env>
